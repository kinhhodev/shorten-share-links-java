# Docker Hub credentials
DOCKER_USERNAME=
DOCKER_PASSWORD=

# Optional OAuth2 (Vite dev frontend on :5173, backend on :8080)
# GitHub OAuth App "Authorization callback URL" must be:
#   http://localhost:8080/login/oauth2/code/github
# Example:
#   SPRING_PROFILES_ACTIVE=oauth2
#   PUBLIC_BASE_URL=http://localhost:5173
#   OAUTH2_AUTHORIZATION_CALLBACK_BASE_URL=http://localhost:8080
#   OAUTH2_REDIRECT_URI=http://localhost:5173/auth/callback
# GitHub callback URL in the app settings: http://localhost:8080/login/oauth2/code/github
#SPRING_PROFILES_ACTIVE=docker,oauth2
#PUBLIC_BASE_URL=http://localhost:5173
#OAUTH2_AUTHORIZATION_CALLBACK_BASE_URL=http://localhost:8080
#OAUTH2_REDIRECT_URI=http://localhost:5173/auth/callback
#OAUTH2_GITHUB_CLIENT_ID=
#OAUTH2_GITHUB_CLIENT_SECRET=
#OAUTH2_GOOGLE_CLIENT_ID=
#OAUTH2_GOOGLE_CLIENT_SECRET=